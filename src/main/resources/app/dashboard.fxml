<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.shape.SVGPath?>
<AnchorPane fx:id="rootPane" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">

    <BorderPane fx:id="mainBorderPane" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <top>
            <HBox alignment="CENTER" prefHeight="60" spacing="20" style="-fx-background-color: white;             -fx-border-color: #e0e0e0;             -fx-border-width: 0 0 1 0;">

                <padding>
                    <Insets bottom="20" left="20" top="20" />
                </padding>

                <Label style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #4f5dff" text="eDiploma" />
            </HBox>
        </top>

        <!-- Enhanced left sidebar with better styling and visual hierarchy -->
        <left>
            <VBox prefWidth="240" spacing="4.0" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">

                <padding>
                    <Insets bottom="20.0" top="30.0" />
                </padding>


                <Label fx:id="radoviLabel" onMouseClicked="#handleRadoviClick" style="-fx-cursor: hand;                               -fx-padding: 12 20 12 20;                               -fx-font-size: 14;                               -fx-font-weight: 500;                               -fx-text-fill: #424242;                               -fx-background-radius: 8;                               -fx-background-color: transparent;" text="Završni radovi">
                    <VBox.margin>
                        <Insets left="12.0" right="12.0" />
                    </VBox.margin>
                </Label>

                <Label fx:id="studentiLabel" onMouseClicked="#handleStudentiClick" style="-fx-cursor: hand;                               -fx-padding: 12 20 12 20;                               -fx-font-size: 14;                               -fx-font-weight: 500;                               -fx-text-fill: #424242;                               -fx-background-radius: 8;                               -fx-background-color: transparent;" text="Studenti">
                    <VBox.margin>
                        <Insets left="12.0" right="12.0" />
                    </VBox.margin>
                </Label>

                <Label fx:id="mentoriLabel" onMouseClicked="#handleMentoriClick" style="-fx-cursor: hand;                               -fx-padding: 12 20 12 20;                               -fx-font-size: 14;                               -fx-font-weight: 500;                               -fx-text-fill: #424242;                               -fx-background-radius: 8;                               -fx-background-color: transparent;" text="Mentori">
                    <VBox.margin>
                        <Insets left="12.0" right="12.0" />
                    </VBox.margin>
                </Label>

                <!-- NEW: Secretaries -->
                <Label fx:id="sekretariLabel" onMouseClicked="#handleSekretariClick" style="-fx-cursor: hand;                               -fx-padding: 12 20 12 20;                               -fx-font-size: 14;                               -fx-font-weight: 500;                               -fx-text-fill: #424242;                               -fx-background-radius: 8;                               -fx-background-color: transparent;" text="Sekretari">
                    <VBox.margin>
                        <Insets left="12.0" right="12.0" />
                    </VBox.margin>
                </Label>

                <Label fx:id="statistikaLabel" onMouseClicked="#handleStatisticsClick" style="-fx-cursor: hand;                               -fx-padding: 12 20 12 20;                               -fx-font-size: 14;                               -fx-font-weight: 500;                               -fx-text-fill: #424242;                               -fx-background-radius: 8;                               -fx-background-color: transparent;" text="Statistika">
                    <VBox.margin>
                        <Insets left="12.0" right="12.0" />
                    </VBox.margin>
                </Label>

                <Region VBox.vgrow="ALWAYS" />

                <Separator style="-fx-background-color: #f0f0f0;">
                    <VBox.margin>
                        <Insets bottom="16.0" />
                    </VBox.margin>
                </Separator>

                <!-- NEW: Account Settings link -->
                <Label fx:id="accountSettingsLabel"
                       onMouseClicked="#handleAccountSettings"
                       text="Postavke"
                       style="-fx-cursor: hand; -fx-padding: 12 20 12 20; -fx-font-size: 14; -fx-font-weight: 500; -fx-text-fill: #424242; -fx-background-radius: 8; -fx-background-color: transparent;">

                    <VBox.margin>
                        <Insets left="12.0" right="12.0" />
                    </VBox.margin>

                    <graphic>
                        <SVGPath fill="#424242" scaleX="0.75" scaleY="0.75"
                                 content="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" />
                    </graphic>
                </Label>

                <Label fx:id="lblOdjava"
                       onMouseClicked="#handleLogout"
                       text="Odjava"
                       style="-fx-cursor: hand; -fx-padding: 12 20 12 20; -fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #d32f2f; -fx-background-radius: 8; -fx-background-color: transparent;">

                    <VBox.margin>
                        <Insets left="12.0" right="12.0" />
                    </VBox.margin>

                    <graphic>
                        <SVGPath fill="#d32f2f" scaleX="0.75" scaleY="0.75"
                                 content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                    </graphic>
                </Label>
            </VBox>
        </left>

        <!-- CENTER CONTENT -->
        <center>
            <StackPane style="-fx-background-color: #f9f9f9;">
                <Label style="-fx-font-size: 18;                                  -fx-font-weight: bold;" text="Obavijesti" StackPane.alignment="TOP_CENTER">
                    <StackPane.margin>
                        <Insets left="30.0" right="30.0" top="10.0" />
                    </StackPane.margin></Label>
                <BorderPane.margin>
                    <Insets />
                </BorderPane.margin>
            </StackPane>
        </center>

    </BorderPane>

</AnchorPane>